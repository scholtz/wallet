{
  "compilerOptions": {
    "target": "esnext",
    "module": "esnext",
    "strict": true,
    "ignoreDeprecations": "6.0",
    "jsx": "preserve",
    "importHelpers": true,
    "moduleResolution": "node",
    "allowArbitraryExtensions": true,
    "experimentalDecorators": true,
    "allowJs": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "sourceMap": true,
    "baseUrl": ".",
    "types": ["vite/client"],
    "paths": {
      "@/*": ["src/*"],
      "@primeuix/themes/aura": [
        "node_modules/@primeuix/themes/dist/aura/index.d.ts"
      ]
    },
    "lib": ["esnext", "dom", "dom.iterable", "scripthost"]
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/**/*.d.ts",
    "src/**/*.vue",
    "tests/**/*.ts",
    "tests/**/*.tsx",
    "src/store/fa2.ts",
    "src/shared/wc.ts",
    "src/store/index.ts"
  ],
  "exclude": ["node_modules"]
}
