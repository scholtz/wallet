{
  "name": "wallet",
  "version": "2.0.0",
  "private": false,
  "packageManager": "pnpm@11.10.0",
  "scripts": {
    "dev": "vite",
    "serve": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "lint": "eslint . --fix",
    "check-typescript-errors-tsc": "npx tsc --noEmit",
    "check-typescript-errors-vue": "npx vue-tsc --noEmit",
    "check-locales": "pnpm run build:scripts && node scripts/check-locales.js",
    "cypress": "cypress run",
    "cypress:open": "cypress open",
    "cypress:run": "cypress run --config-file cypress.config.ts",
    "cypress:run-video": "cypress run --config-file cypress.config.video.ts",
    "server": "browser-sync start --config bs-config.js",
    "server2": "node -e \"const http = require('http'); const fs = require('fs'); const path = require('path'); const server = http.createServer((req, res) => { let filePath = path.join(__dirname, 'dist', req.url === '/' ? 'index.html' : req.url); fs.access(filePath, fs.constants.F_OK, (err) => { if (err) { res.writeHead(404); res.end('Not Found'); return; } fs.readFile(filePath, (err, data) => { if (err) { res.writeHead(500); res.end('Internal Server Error'); return; } const ext = path.extname(filePath); const contentType = { '.html': 'text/html', '.js': 'application/javascript', '.css': 'text/css', '.json': 'application/json', '.png': 'image/png', '.jpg': 'image/jpeg', '.svg': 'image/svg+xml' }[ext] || 'text/plain'; res.writeHead(200, { 'Content-Type': contentType }); res.end(data); }); }); }); server.listen(8080, () => console.log('Server running at http://localhost:8080'));\"",
    "run-app-for-test": "pnpm run serve -- --port 8080",
    "build:scripts": "tsc -p tsconfig.scripts.json",
    "test": "pnpm run build:scripts && node scripts/run-tests.js",
    "test:parallel": "run-p server cypress:run",
    "test:video": "run-p server cypress:run-video",
    "test:prepare": "pnpm run build",
    "test:arc76": "node scripts/run-test-with-server.js cypress run --config-file cypress.config.video.ts --spec 'cypress/e2e/2-setup-account/create-arc76-account.cy.ts'",
    "test:ed25519": "node scripts/run-test-with-server.js cypress run --config-file cypress.config.video.ts --spec 'cypress/e2e/2-setup-account/create-ed25519-account.cy.ts'",
    "test:hd-wallet": "node scripts/run-test-with-server.js cypress run --config-file cypress.config.video.ts --spec 'cypress/e2e/2-setup-account/create-hd-wallet-account.cy.ts'",
    "test:basic": "node scripts/run-test-with-server.js cypress run --config-file cypress.config.video.ts --spec 'cypress/e2e/1-basic-tests/load-index.cy.ts'",
    "test:open": "run-p server cypress:open",
    "playwright:install": "playwright install chromium",
    "playwright:test": "playwright test",
    "playwright:test:multisig-flow": "playwright test create-multisig-flow.spec.ts",
    "playwright:test:ed25519-export-shamir-recover": "playwright test ed25519-export-shamir-recover.spec.ts",
    "playwright:report": "playwright show-report"
  },
